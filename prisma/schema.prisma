generator client {
  provider = "prisma-client-js"
  output   = "./generated/mindsai_platform"
}

datasource db {
  provider = "mysql"
  url      = env("PRISMA_DATABASE_URL")
}

model user {
  id             Int       @id @default(autoincrement())
  email          String?   @unique(map: "user_pk") @db.VarChar(255)
  password       String?   @db.VarChar(255)
  name           String?   @db.VarChar(30)
  created_at     DateTime? @default(dbgenerated("(now())")) @db.Timestamp(0)
  account_status String?   @default("ACTIVE") @db.VarChar(30)
  board          board[]
}

model board {
  id          Int     @id @default(autoincrement())
  title       String? @db.VarChar(255)
  description String? @db.VarChar(255)
  status      String? @db.VarChar(255)
  user_id     Int
  user        user    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "board_user_id_fk")

  @@index([user_id], map: "board_user_id_fk")
}
