generator client {
  provider = "prisma-client-js"
  output   = "./generated/nest_prisma_template"
}

datasource db {
  provider = "mysql"
  url      = env("PRISMA_DATABASE_URL")
}

model User {
  id            Int       @id @default(autoincrement())
  email         String?   @unique(map: "user_pk") @db.VarChar(255)
  password      String?   @db.VarChar(255)
  name          String?   @db.VarChar(30)
  createdAt     DateTime? @default(dbgenerated("(now())")) @map("created_at") @db.Timestamp(0)
  accountStatus String?   @default("ACTIVE") @map("account_status") @db.VarChar(20)
  board         Board[]

  @@map("user")
}

model Board {
  id          Int     @id @default(autoincrement())
  title       String? @db.VarChar(255)
  description String? @db.VarChar(255)
  status      String? @db.VarChar(255)
  userId      Int     @map("user_id")
  user        User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "board_user_id_fk")

  @@index([userId], map: "board_user_id_fk")
  @@map("board")
}

model Message {
  id        Int      @id @default(autoincrement())
  room      String // 채팅방 이름
  author    String
  content   String
  createdAt DateTime @default(now())
}
