# ================================
# Docker Environment Variables
# ================================
# 이 파일을 .env.docker로 복사하여 사용하세요
# cp .env.docker.example .env.docker

# ================================
# Server
# ================================
NODE_ENV=production
PORT=4010
SOCKETPORT=4011
TIMEZONE=Asia/Seoul
LOG_LEVEL=info

# ================================
# Database (MySQL)
# ================================
DB_HOST=mysql
DB_PORT=3306
DB_NAME=nest_template
DB_USER=appuser
DB_PASSWORD=your_secure_password
DB_ROOT_PASSWORD=your_root_password

# ================================
# Redis
# ================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ================================
# JWT
# ================================
ACCESS_TOKEN_SECRET_KEY=your_access_token_secret_key_min_32_chars
REFRESH_TOKEN_SECRET_KEY=your_refresh_token_secret_key_min_32_chars
ACCESS_TOKEN_EXPIRES_IN=6h
REFRESH_TOKEN_EXPIRES_IN=24h

# ================================
# Email (Optional)
# ================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# ================================
# Encryption (Optional)
# ================================
ENCRYPTION_SECRET_KEY=your_32_char_encryption_key_here
