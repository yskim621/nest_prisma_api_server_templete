{
  "name": "mindsai_central_api_server",
  "private": true,
  "version": "1.0.0",
  "description": "mindsai platform api repository",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "build:gateway": "nest build api-gateway",
    "build:auth": "nest build auth-service",
    "build:core": "nest build core-service",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\" \"test/**/*.ts\"",
    "start:gateway": "cross-env NODE_ENV=local nest start api-gateway",
    "start:auth": "cross-env NODE_ENV=local nest start auth-service",
    "start:core": "cross-env NODE_ENV=local nest start core-service",
    "start:gateway:dev": "cross-env NODE_ENV=local nest start api-gateway --watch",
    "start:auth:dev": "cross-env NODE_ENV=local nest start auth-service --watch",
    "start:core:dev": "cross-env NODE_ENV=local nest start core-service --watch",
    "start:all:dev": "concurrently \"npm run start:gateway:dev\" \"npm run start:auth:dev\" \"npm run start:core:dev\"",
    "start:debug": "nest start api-gateway --debug --watch",
    "start:prod:gateway": "node dist/apps/api-gateway/main",
    "start:prod:auth": "node dist/apps/auth-service/main",
    "start:prod:core": "node dist/apps/core-service/main",
    "lint": "eslint \"{apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up",
    "docker:dev:build": "docker-compose -f docker-compose.dev.yml up --build",
    "docker:dev:debug": "docker-compose -f docker-compose.dev.yml -f docker-compose.debug.yml up",
    "docker:dev:debug:build": "docker-compose -f docker-compose.dev.yml -f docker-compose.debug.yml up --build",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:prod": "docker-compose up",
    "docker:prod:build": "docker-compose up --build",
    "docker:prod:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:logs:dev": "docker-compose -f docker-compose.dev.yml logs -f",
    "docker:clean": "docker-compose down -v --rmi local",
    "docker:clean:dev": "docker-compose -f docker-compose.dev.yml down -v --rmi local",
    "prisma:format": "npx prisma-case-format -f prisma/schema.prisma --table-case=pascal,singular --field-case=camel --map-field-case=snake"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@google-cloud/firestore": "^7.11.0",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/microservices": "^11.1.16",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/websockets": "^11.1.6",
    "@prisma/adapter-mariadb": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "amqplib": "^0.10.9",
    "axios": "^1.9.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "firebase-admin": "^13.3.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "mariadb": "^3.5.2",
    "moment-timezone": "^0.5.48",
    "passport-jwt": "^4.0.1",
    "pm2": "^6.0.6",
    "prisma-case-format": "^2.2.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.8",
    "@types/amqplib": "^0.10.8",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/helmet": "^4.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.14",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-prettier": "^5.2.6",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "prisma": "^7.5.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core"
    ]
  }
}
